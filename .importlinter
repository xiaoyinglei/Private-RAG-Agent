[importlinter]
root_package = rag

[importlinter:contract:schema_foundation]
name = Schema remains independent from agent orchestration
type = forbidden
source_modules =
    rag.schema
forbidden_modules =
    rag.agent

[importlinter:contract:tools_boundary]
name = Tools do not depend on agent orchestration
type = forbidden
source_modules =
    rag.agent.tools
forbidden_modules =
    rag.agent.graphs
    rag.agent.service
    rag.cli
ignore_imports =
    rag.agent.tools.builtin_registry -> rag.agent.builtin_registry

[importlinter:contract:memory_boundary]
name = Memory does not depend on agent orchestration
type = forbidden
source_modules =
    rag.agent.memory
forbidden_modules =
    rag.agent.graphs
    rag.agent.service
    rag.cli
