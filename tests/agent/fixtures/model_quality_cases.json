{
  "schema_version": 1,
  "suite_id": "agent-model-tool-quality-v1",
  "models": [
    "qwen3_5_9b_mlx_4bit",
    "groq_gpt_oss_120b"
  ],
  "cases": [
    {
      "id": "exact_file_read",
      "capability": "file_tool_selection",
      "task": "Read the attached file exact.txt with the most direct file tool. Return exactly QUALITY_GATE_EXACT and no other text.",
      "workspace_files": {
        "exact.txt": "QUALITY_GATE_EXACT\n"
      },
      "expected_answer_contains": "QUALITY_GATE_EXACT",
      "expected_first_tool": "read_file",
      "require_first_tool": true,
      "expected_tool_sequence": [
        "read_file"
      ],
      "expected_tool_calls": [
        {
          "tool_name": "read_file",
          "arguments": {
            "path": "input_files/exact.txt"
          }
        }
      ]
    },
    {
      "id": "symbol_search_then_read",
      "capability": "file_tool_selection",
      "task": "Find the file containing MODEL_QUALITY_TARGET with search_text, then read that matching file with read_file. Return exactly TARGET_VALUE_731 and no other text.",
      "workspace_files": {
        "alpha.py": "ALPHA = 1\n",
        "target.py": "MODEL_QUALITY_TARGET = 'TARGET_VALUE_731'\n"
      },
      "expected_answer_contains": "TARGET_VALUE_731",
      "expected_first_tool": "search_text",
      "expected_tool_sequence": [
        "search_text",
        "read_file"
      ],
      "expected_tool_calls": [
        {
          "tool_name": "search_text",
          "arguments": {
            "pattern": "MODEL_QUALITY_TARGET"
          }
        },
        {
          "tool_name": "read_file",
          "arguments": {
            "path": "input_files/target.py"
          }
        }
      ]
    },
    {
      "id": "missing_file_recovery",
      "capability": "failure_recovery",
      "task": "First call read_file on input_files/report.txt. That old path may fail. If it fails, recover with the available file tools, locate the renamed report, read it, and return exactly RECOVERED_842 and no other text.",
      "workspace_files": {
        "report-final.txt": "RECOVERED_842\n"
      },
      "expected_answer_contains": "RECOVERED_842",
      "expected_first_tool": "read_file",
      "intentional_error_tool": "read_file",
      "expected_failed_call": {
        "tool_name": "read_file",
        "arguments": {
          "path": "input_files/report.txt"
        }
      },
      "expected_recovery_call": {
        "tool_name": "read_file",
        "arguments": {
          "path": "input_files/report-final.txt"
        }
      },
      "recovery_tools": [
        "list_files",
        "search_text",
        "read_file"
      ]
    },
    {
      "id": "approval_continue",
      "capability": "approval_continuation",
      "task": "Change the unique text before_gate to after_gate in the attached approval.txt using apply_patch, then confirm completion.",
      "workspace_files": {
        "approval.txt": "before_gate\n"
      },
      "expected_first_tool": "apply_patch",
      "expected_tool_sequence": [
        "apply_patch"
      ],
      "expected_tool_calls": [
        {
          "tool_name": "apply_patch",
          "arguments": {
            "file_path": "input_files/approval.txt",
            "new_string": "after_gate",
            "old_string": "before_gate"
          }
        }
      ],
      "auto_approve": true,
      "workspace_assertions": {
        "input_files/approval.txt": "after_gate\n"
      }
    },
    {
      "id": "single_failure_no_retry",
      "capability": "repeated_failure_control",
      "task": "Try read_file on input_files/definitely-missing.txt exactly once. If it reports that the file is missing, do not retry the same call and do not use another tool. Return exactly FILE_UNAVAILABLE and no other text.",
      "workspace_files": {},
      "expected_answer_contains": "FILE_UNAVAILABLE",
      "expected_first_tool": "read_file",
      "intentional_error_tool": "read_file",
      "expected_failed_call": {
        "tool_name": "read_file",
        "arguments": {
          "path": "input_files/definitely-missing.txt"
        }
      },
      "max_identical_failed_calls": 1
    }
  ]
}
