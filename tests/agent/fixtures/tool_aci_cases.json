      "allow_discovery_tools": false,
      "expected_surface": ["list_files"],
      "expected_tool": "list_files",
      "fake_tool": "list_files",
      "fake_arguments": {
        "path": "input_files",
        "glob": "*.py",
        "limit": 20
      }
    },
    {
      "id": "workspace_grep",
      "category": "grep",
      "prompt": "Use Grep to locate class AgentService in workspace source.",
